<Window x:Class="AndromedaShop.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="580" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F2F5">
    <Grid>
        <Border Background="White" CornerRadius="6" Margin="16">
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="8" ShadowDepth="1" Opacity="0.4"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="lblTitle"
                               Text="Новый товар"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"
                               Margin="0,0,0,16"/>

                    <!-- Наименование -->
                    <TextBlock Text="Наименование *" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtName" Height="34" Margin="0,0,0,10"/>

                    <!-- Артикул -->
                    <TextBlock Text="Артикул" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtArticle" Height="34" Margin="0,0,0,10"/>

                    <!-- Описание -->
                    <TextBlock Text="Описание" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtDescription"
                             Height="70"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,10"/>

                    <!-- Категория -->
                    <TextBlock Text="Категория *" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbCategory" Height="34" Margin="0,0,0,10" DisplayMemberPath="Name"/>

                    <!-- Производитель -->
                    <TextBlock Text="Производитель" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbManufacturer" Height="34" Margin="0,0,0,10" DisplayMemberPath="Name"/>

                    <!-- Поставщик -->
                    <TextBlock Text="Поставщик" FontSize="12" Foreground="#555" Margin="0,0,0,10"/>
                    <ComboBox x:Name="cbSupplier" Height="34" Margin="0,0,0,10" DisplayMemberPath="Name"/>

                    <!-- Единица измерения -->
                    <TextBlock Text="Единица измерения" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbUnit" Height="34" Margin="0,0,0,10" DisplayMemberPath="Name"/>

                    <!-- Цена и Скидка -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Цена (руб.) *" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtPrice" Height="34"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Скидка (%)" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtDiscount" Height="34" Text="0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Изображение -->
                    <TextBlock Text="Изображение" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image x:Name="imgPreview"
                               Grid.Column="0"
                               Height="80"
                               Stretch="Uniform"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="0,0,0,0"/>
                        <Button Grid.Column="2"
                                Content="Выбрать..."
                                Style="{StaticResource PrimaryButton}"
                                Height="34"
                                Click="BtnChooseImage_Click"/>
                    </Grid>

                    <!-- Кнопки -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Сохранить"
                                Style="{StaticResource SuccessButton}"
                                Height="38"
                                Click="BtnSave_Click"/>
                        <Button Grid.Column="2"
                                Content="Отмена"
                                Height="38"
                                Background="#BDC3C7"
                                Foreground="White"
                                BorderThickness="0"
                                Click="BtnCancel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#95A5A6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
