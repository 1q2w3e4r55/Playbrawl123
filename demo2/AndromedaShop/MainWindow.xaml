<Window x:Class="AndromedaShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Andromeda Shop"
        Height="640" Width="960"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        FontFamily="Comic Sans MS"
        Icon="app.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель — акцентный цвет #546F94 -->
        <Border Grid.Row="0" Background="#546F94">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Логотип -->
                    <Image Source="app.ico" Width="32" Height="32" Margin="0,0,10,0"/>
                    <TextBlock Text="Andromeda Shop"
                               Foreground="White" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"
                               FontFamily="Comic Sans MS"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="lblUser"
                               Foreground="#ABCFCE" FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               FontFamily="Comic Sans MS"/>
                    <Button Content="Выйти"
                            Style="{StaticResource DangerButton}"
                            Padding="10,5"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковое меню — дополнительный фон #ABCFCE -->
            <Border Grid.Column="0" Background="#ABCFCE">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="НАВИГАЦИЯ"
                               Foreground="#546F94" FontSize="10" FontWeight="Bold"
                               Margin="16,0,0,12"
                               FontFamily="Comic Sans MS"/>

                    <Button x:Name="btnProducts"
                            Content="  Товары"
                            Height="44"
                            Background="Transparent"
                            Foreground="#546F94"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="16,0"
                            Cursor="Hand"
                            FontFamily="Comic Sans MS"
                            Click="BtnProducts_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#546F94"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnOrders"
                            Content="  Заказы"
                            Height="44"
                            Background="Transparent"
                            Foreground="#546F94"
                            FontSize="14"
                            FontWeight="Bold"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="16,0"
                            Cursor="Hand"
                            FontFamily="Comic Sans MS"
                            Click="BtnOrders_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#546F94"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Контент -->
            <Frame x:Name="MainFrame"
                   Grid.Column="1"
                   NavigationUIVisibility="Hidden"
                   Background="#FFFFFF"/>
        </Grid>
    </Grid>
</Window>
