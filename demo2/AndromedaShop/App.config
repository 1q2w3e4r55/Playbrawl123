<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════════════╗
  ║           РУКОВОДСТВО ПО НАСТРОЙКЕ И ЗАПУСКУ ANDROMEDA SHOP             ║
  ╠══════════════════════════════════════════════════════════════════════════╣
  ║                                                                          ║
  ║  1. КАК ОТКРЫТЬ ПРОЕКТ В VISUAL STUDIO                                  ║
  ║     Откройте файл: demo1\AndromedaShop\AndromedaShop.csproj             ║
  ║     или demo1\demo.sln → правая кнопка на AndromedaShop →               ║
  ║     "Set as Startup Project" → F5                                        ║
  ║                                                                          ║
  ║  2. ГДЕ ИЗМЕНИТЬ СТРОКУ ПОДКЛЮЧЕНИЯ                                     ║
  ║     Прямо в этом файле (App.config) в секции <connectionStrings>        ║
  ║     Измените параметры Data Source и Initial Catalog                     ║
  ║                                                                          ║
  ║  3. КАК УЗНАТЬ ИМЯ СЕРВЕРА ЧЕРЕЗ SSMS                                  ║
  ║     Откройте SSMS → в поле "Server name" вверху будет имя сервера.      ║
  ║     Или выполните запрос: SELECT @@SERVERNAME                            ║
  ║     Типичные варианты:                                                   ║
  ║       .\SQLEXPRESS          — локальный SQL Server Express               ║
  ║       localhost\SQLEXPRESS  — то же самое                               ║
  ║       DESKTOP-XXXX\SQLEXPRESS — конкретное имя ПК\экземпляр            ║
  ║                                                                          ║
  ║  4. КАК УЗНАТЬ ИМЯ БАЗЫ ДАННЫХ                                         ║
  ║     В SSMS в дереве Object Explorer → Databases → имя вашей БД          ║
  ║     Или выполните: SELECT name FROM sys.databases                        ║
  ║                                                                          ║
  ║  5. КАК ПРОВЕРИТЬ ПОДКЛЮЧЕНИЕ                                           ║
  ║     В SSMS нажмите "Connect" с теми же параметрами.                     ║
  ║     Если подключается — приложение тоже подключится.                    ║
  ║                                                                          ║
  ║  6. ЕСЛИ ИСПОЛЬЗУЕТЕ SQL-АУТЕНТИФИКАЦИЮ (не Windows)                   ║
  ║     Замените Integrated Security=True на:                               ║
  ║     User ID=ваш_логин;Password=ваш_пароль                               ║
  ║                                                                          ║
  ╚══════════════════════════════════════════════════════════════════════════╝
-->
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>

  <connectionStrings>
    <!--
      ┌─────────────────────────────────────────────────────────────────┐
      │ СТРОКА ПОДКЛЮЧЕНИЯ К БАЗЕ ДАННЫХ                                │
      │                                                                 │
      │ Data Source    = имя сервера SQL Server                         │
      │   Примеры:                                                      │
      │     .\SQLEXPRESS              (локальный, рекомендуется)        │
      │     localhost\SQLEXPRESS      (то же самое)                     │
      │     DESKTOP-ABC123\SQLEXPRESS (имя конкретного ПК)             │
      │     ANDREYYYYY\SQLEXPRESS     (имя конкретного ПК)             │
      │                                                                 │
      │ Initial Catalog = название вашей базы данных                    │
      │   Пример: Andromeda                                             │
      │                                                                 │
      │ Integrated Security=True — используется Windows-авторизация     │
      │ (тот же пользователь, что вошёл в Windows)                      │
      │                                                                 │
      │ Если нужна SQL-аутентификация — замените на:                    │
      │   Integrated Security=False;User ID=sa;Password=ВашПароль      │
      └─────────────────────────────────────────────────────────────────┘
    -->
    <add name="AndromedaDB"
         connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=Andromeda;Integrated Security=True"
         providerName="System.Data.SqlClient"/>

    <!--
      ПРИМЕРЫ строк подключения для разных ситуаций (раскомментируйте нужную):

      Локальный SQL Express (универсальный):
      connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=Andromeda;Integrated Security=True"

      Конкретный ПК:
      connectionString="Data Source=ANDREYYYYY\SQLEXPRESS;Initial Catalog=Andromeda;Integrated Security=True"

      SQL-аутентификация:
      connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=Andromeda;Integrated Security=False;User ID=sa;Password=ВашПароль"

      Полный SQL Server (не Express):
      connectionString="Data Source=.\MSSQLSERVER;Initial Catalog=Andromeda;Integrated Security=True"
    -->
  </connectionStrings>
</configuration>
