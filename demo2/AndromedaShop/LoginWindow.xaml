<Window x:Class="AndromedaShop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему — Andromeda Shop"
        Height="420" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        FontFamily="Comic Sans MS"
        Icon="app.ico">
    <Grid Background="#FFFFFF">
        <Border Background="#FFFFFF"
                CornerRadius="8"
                Margin="30">
            <Border.Effect>
                <DropShadowEffect Color="#ABCFCE" BlurRadius="12" ShadowDepth="2" Opacity="0.6"/>
            </Border.Effect>
            <StackPanel Margin="30" VerticalAlignment="Center">

                <!-- Логотип -->
                <Image Source="app.ico"
                       Width="48" Height="48"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

                <!-- Заголовок -->
                <TextBlock Text="Andromeda Shop"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#546F94"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Информационная система интернет-магазина"
                           FontSize="11" Foreground="#546F94"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Логин -->
                <TextBlock Text="Логин" FontSize="12" Foreground="#546F94" Margin="0,0,0,4"/>
                <TextBox x:Name="txtLogin"
                         Height="36"
                         FontSize="13"
                         Margin="0,0,0,14"
                         KeyDown="Input_KeyDown"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль" FontSize="12" Foreground="#546F94" Margin="0,0,0,4"/>
                <PasswordBox x:Name="txtPassword"
                             Height="36"
                             FontSize="13"
                             Margin="0,0,0,6"
                             KeyDown="Input_KeyDown"/>

                <!-- Ошибка -->
                <TextBlock x:Name="lblError"
                           Foreground="#C0392B"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Visibility="Collapsed"/>

                <!-- Кнопка -->
                <Button Content="Войти"
                        Height="40"
                        FontSize="14"
                        Click="BtnLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
